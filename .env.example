# Copy this to .env and fill in your values.
# .env is gitignored — never commit real credentials.

AWS_REGION=ap-southeast-1

# From Terraform outputs (run ./scripts/deploy.sh first, or fill manually):
DOCUMENTS_BUCKET=vectorless-rag-docs-YOUR_ACCOUNT_ID
DYNAMODB_TABLE=vectorless-rag-rag-index

# Bedrock model ID (must be enabled in your region):
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Optional: increase for higher-quality results at the cost of more context tokens
MAX_RETRIEVED_NODES=5
